datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  password      String?        // Hashed password for credentials login
  role          UserRole       @default(CUSTOMER)
  address       String?
  city          String?
  mobile        String?
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  orders        Order[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Float
  image       String
  stock       Int         @default(0)
  active      Boolean     @default(true)
  category    String      @default("General") // e.g., "Groceries", "Gas cylinder", "Fridge", "Air Conditioner"
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Service {
  id          String    @id @default(cuid())
  name        String
  description String
  price       Float
  duration    Int       @default(60) // Duration in minutes
  image       String
  active      Boolean   @default(true)
  category    String    @default("General") // e.g., "Car service", "Air Conditioner", "Fridge"
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  date          DateTime
  timeSlot      String   // e.g., "09:00 AM", "10:00 AM"
  paymentMethod String   @default("PAY_ON_SERVICE") // "PAY_ON_SERVICE", "BKASH", "NAGAD"
  paymentStatus String   @default("PENDING")        // "PENDING", "PAID"
  status        String   @default("PENDING")        // "PENDING", "CONFIRMED", "CANCELLED"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingAddress String?
  city            String?
  mobile          String?
  paymentMethod   String      @default("CASH_ON_DELIVERY") // "CASH_ON_DELIVERY", "BKASH", "NAGAD"
  paymentStatus   String      @default("PENDING")          // "PENDING", "PAID"
  status          String      @default("PENDING")          // "PENDING", "CONFIRMED", "SHIPPED", "DELIVERED", "CANCELLED"
  totalAmount     Float
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("SYSTEM") // "DELIVERY", "PROMO", "CONFIRM", "SYSTEM"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
